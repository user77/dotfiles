            "deactivated": "´ü░"
        }
    },
    "tray": {
        "icon-size": 20,
        "spacing": 6
    },
    "clock": {
        "interval": 1,
        "locale": "C", 
        "format": "´Çù {:%H:%M}", // Clamped space
        "format-alt": "´ü│ {:%a,%b %d}"
    },
    "cpu": {
        "format": "´ïø {usage}%",
        "tooltip": false,
        "on-click": "kitty -e 'btop'"
    },
    "memory": {
        "interval": 30,
        "format": "¾░ıø {used:0.2f}GB",
        "max-length": 10,
        "tooltip": false,
        "warning": 70,
        "critical": 90,
        "on-click": "kitty ~/.local/bin/waybar-memory-smem"
    },
    "temperature": {
        "thermal-zone": 0,
        "hwmon-path-abs": "/sys/devices/platform/thinkpad_hwmon/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["´ïï", "´ïë", "´ïç"],
        "on-click": "kitty s-tui"
    },
    "disk": {
        "interval": 30,
        "format": "¾░ïè {percentage_used}%",
        "path": "/",
        "on-click": "kitty --hold sh -c 'dust -r -b / 2>/dev/null'"
    },
    "backlight": {
        "format": "{icon} {percent}%", // Clamped space
        "format-icons": ["´åå", "´åà"],
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%", // Clamped space
