        "hyprland/workspaces",
        "cpu",
        "temperature",
        "memory",
        "disk",
        "network", 
        "custom/recorder", 
        "custom/audiorec"
    ],
    "modules-center": [
        "tray",
        "mpd"
    ],
    "modules-right": [
        "idle_inhibitor",
        "custom/separator",
        "backlight", 
        "custom/separator",
        "battery",
        "power-profiles-daemon",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "clock"
    ],

